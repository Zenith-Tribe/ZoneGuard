# Database
DATABASE_URL=postgresql+asyncpg://zoneguard:zoneguard_dev@localhost:5432/zoneguard

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# External APIs
OPENWEATHERMAP_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here

# App config
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# Session 1 — ZoneChain + TemporalSig
FABRIC_GATEWAY_URL=localhost:7051
FABRIC_CHANNEL=zoneguard-channel
FABRIC_CHAINCODE=zoneguard-cc
FABRIC_MSP_ID=ZoneGuardMSP
FABRIC_CERT_PEM=
FABRIC_PRIVATE_KEY_PEM=
FABRIC_TLS_CERT_PEM=
FABRIC_PEER_HOSTNAME=peer0.org1.example.com
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_PRIVATE_KEY=
POLYGON_NETWORK=amoy
TEMPORALSIG_CONTRACT_ADDRESS=

# Session 2 — ChainOracle
ORACLE_MODE=false
IMD_API_KEY=
ACCUWEATHER_API_KEY=
GOOGLE_MOBILITY_API_KEY=
ORACLE_HMAC_SECRET=change-me-in-prod
CHAINCODE_MOCK_MODE=true

# Session 3 — ZK Identity
ZK_TEE_MODE=simulate
ZONEGUARD_SIGNING_KEY=
ZK_IDENTITY_BASE_URL=http://localhost:8001
ZONEGUARD_NFT_SALT=zg-nft-salt-dev-2025

# Session 4 — ML
FEDSHIELD_V3_ENABLED=false
ADAPT_PREMIUM_SHADOW_MODE=true
PPO_MODEL_PATH=/models/adapt_ppo
GAN_MODEL_DIR=/models/zone_twin_gan
GAN_ENABLED=false

# Session 5 — Governance
ZK_IDENTITY_BASE_URL=http://localhost:8001